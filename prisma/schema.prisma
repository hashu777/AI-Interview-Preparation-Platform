generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  name           String
  passwordHash   String
  emailVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions       Session[]
  tokens         AuthToken[]
  resumes        Resume[]
  interviewSessions InterviewSession[]
  codingSubmissions CodingSubmission[]
}

model CodingProblem {
  id          String            @id @default(uuid()) @db.Uuid
  slug        String            @unique
  title       String
  description String
  difficulty  CodingDifficulty
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  testCases   CodingTestCase[]
  submissions CodingSubmission[]
}

model CodingTestCase {
  id        String        @id @default(uuid()) @db.Uuid
  problemId String        @db.Uuid
  input     String
  output    String
  isHidden  Boolean       @default(true)
  createdAt DateTime      @default(now())
  problem   CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model CodingSubmission {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @db.Uuid
  problemId          String        @db.Uuid
  language           CodingLanguage
  sourceCode         String
  mode               CodingSubmissionMode
  status             CodingSubmissionStatus
  passedTestCases    Int           @default(0)
  totalTestCases     Int           @default(0)
  stdout             String?
  stderr             String?
  executionTimeMs    Int?
  memoryKb           Int?
  timeComplexity     String?
  complexityFeedback String?
  createdAt          DateTime      @default(now())
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem            CodingProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([problemId, createdAt])
}

model InterviewSession {
  id                   String          @id @default(uuid()) @db.Uuid
  userId               String          @db.Uuid
  isVoice              Boolean         @default(false)
  domain               InterviewDomain
  company              InterviewCompany?
  difficulty           InterviewDifficulty
  durationMinutes      Int
  status               InterviewStatus @default(IN_PROGRESS)
  currentQuestionIndex Int             @default(0)
  finalScore           Int?
  startedAt            DateTime        @default(now())
  completedAt          DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions            InterviewQuestion[]
  evaluation           InterviewEvaluation?
  @@index([userId, status, updatedAt])
  @@index([userId, company, status])
}

model InterviewEvaluation {
  id                String           @id @default(uuid()) @db.Uuid
  sessionId         String           @unique @db.Uuid
  technicalAccuracy Int
  communication     Int
  completeness      Int
  confidence        Int
  problemSolving    Int
  overallScore      Int
  detailedFeedback  String
  idealAnswer       String
  suggestions       String[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model InterviewQuestion {
  id        String           @id @default(uuid()) @db.Uuid
  sessionId String           @db.Uuid
  position  Int
  prompt    String
  createdAt DateTime         @default(now())
  session   InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer    InterviewAnswer?
  @@unique([sessionId, position])
}

model InterviewAnswer {
  id         String            @id @default(uuid()) @db.Uuid
  questionId String            @unique @db.Uuid
  content    String            @default("")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  question   InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Resume {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  title     String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  ResumeVersion[]
  @@index([userId, updatedAt])
}

model ResumeVersion {
  id           String       @id @default(uuid()) @db.Uuid
  resumeId     String       @db.Uuid
  version      Int
  originalName String
  storageKey   String       @unique
  mimeType     String
  byteSize     Int
  status       ResumeStatus @default(PENDING_UPLOAD)
  extractedText String?
  createdAt    DateTime     @default(now())
  resume       Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  analysis     ResumeAnalysis?
  @@unique([resumeId, version])
}

model ResumeAnalysis {
  id              String        @id @default(uuid()) @db.Uuid
  resumeVersionId String        @unique @db.Uuid
  score           Int
  strengths       String[]
  improvements    String[]
  matchedKeywords String[]
  missingKeywords String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  resumeVersion   ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
}

model AuthToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      AuthTokenType
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, type])
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum ResumeStatus {
  PENDING_UPLOAD
  UPLOADED
  EXTRACTION_QUEUED
  EXTRACTED
  FAILED
}

enum InterviewDomain {
  TECHNICAL
  HR
}

enum InterviewCompany {
  GOOGLE
  AMAZON
  MICROSOFT
  INFOSYS
  TCS
  ACCENTURE
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum CodingDifficulty {
  EASY
  MEDIUM
  HARD
}

enum CodingLanguage {
  JAVASCRIPT
  PYTHON
  JAVA
}

enum CodingSubmissionMode {
  RUN
  SUBMIT
}

enum CodingSubmissionStatus {
  ACCEPTED
  WRONG_ANSWER
  COMPILATION_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  EXECUTOR_UNAVAILABLE
}
