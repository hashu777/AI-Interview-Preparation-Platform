{
  "compilerOptions": {
    "module": "NodeNext", "moduleResolution": "NodeNext", "declaration": true, "removeComments": true,
    "emitDecoratorMetadata": true, "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true, "target": "ES2022",
    "sourceMap": true, "outDir": "./dist", "baseUrl": "./",
    "incremental": true, "strict": true, "isolatedModules": true, "skipLibCheck": true
  }, "include": ["src/**/*.ts"]
}
